DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

DB_NAME=skybook_db
DB_USER=postgres
DB_PASSWORD=replace-with-postgres-password
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_CREDENTIALS=true
OPENAI_API_KEY=
AI_VECTOR_DB_PATH=
AI_KNOWLEDGE_BASE_PATH=

FLIGHT_PROVIDER=local_db
HOTEL_PROVIDER=local_db
CAR_PROVIDER=local_db
FLIGHT_PROVIDER_API_KEY=
HOTEL_PROVIDER_API_KEY=
CAR_PROVIDER_API_KEY=
FLIGHT_PROVIDER_BASE_URL=
HOTEL_PROVIDER_BASE_URL=
CAR_PROVIDER_BASE_URL=
HOTEL_PROVIDER_DOMAIN=AR
HOTEL_PROVIDER_LOCALE=es_AR
PROVIDER_REQUEST_TIMEOUT_SECONDS=15
ENABLE_MOCK_PROVIDERS=true
FLIGHT_SEARCH_CACHE_TTL_SECONDS=300
HOTEL_SEARCH_CACHE_TTL_SECONDS=1800
CAR_SEARCH_CACHE_TTL_SECONDS=1800
PROVIDER_SYNC_QUERIES_JSON=

ADMIN_EMAIL=admin@skybook.test
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=SkyBook Admin
ADMIN_TOKEN_TTL_SECONDS=28800
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15
